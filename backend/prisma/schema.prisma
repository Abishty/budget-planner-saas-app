generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum BudgetPeriod {
  MONTHLY
  YEARLY
}

enum FamilyRole {
  OWNER
  MEMBER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  currency     String   @default("USD")
  darkMode     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories     Category[]
  transactions   Transaction[]
  budgets        Budget[]
  goals          Goal[]
  bankAccounts   BankAccount[]
  familiesOwned  Family[]       @relation("FamilyOwner")
  familyMembers  FamilyMember[]
}

model Category {
  id        String          @id @default(cuid())
  userId    String
  name      String
  type      TransactionType
  color     String?
  createdAt DateTime        @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  categoryId  String?
  amount      Decimal         @db.Decimal(14, 2)
  description String?
  date        DateTime
  type        TransactionType
  createdAt   DateTime        @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

model Budget {
  id         String       @id @default(cuid())
  userId     String
  categoryId String
  amount     Decimal      @db.Decimal(14, 2)
  period     BudgetPeriod @default(MONTHLY)
  startDate  DateTime

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Goal {
  id             String    @id @default(cuid())
  userId         String
  name           String
  targetAmount   Decimal   @db.Decimal(14, 2)
  currentAmount  Decimal   @db.Decimal(14, 2) @default(0)
  deadline       DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BankAccount {
  id           String   @id @default(cuid())
  userId       String
  name         String
  institution  String?
  maskedNumber String?
  provider     String?
  externalId   String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Family {
  id          String   @id @default(cuid())
  name        String
  ownerId     String
  createdAt   DateTime @default(now())

  owner   User             @relation("FamilyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members FamilyMember[]
}

model FamilyMember {
  id        String     @id @default(cuid())
  familyId  String
  userId    String
  role      FamilyRole @default(MEMBER)
  joinedAt  DateTime   @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([userId])
}
